{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile SDL2 Game",
            "type": "shell",
            "command": "gcc",
            "args": [
                "main.c",
                "-o",
                "jogo.exe",
                "-IC:/msys64/mingw64/include",
                "-LC:/msys64/mingw64/lib",
                "-lmingw32",
                "-lSDL2main",
                "-lSDL2",
                "-lpthread",
                "-Wno-attributes"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
